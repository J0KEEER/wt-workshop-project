{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "REPLACE_WITH_GITHUB_PAT"
      },
      "//": "Recommendation: Store secrets in environment variables outside this file if possible."
    },
    "stitch": {
      "serverUrl": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "REPLACE_WITH_GOOGLE_STITCH_API_KEY"
      }
    },
    "mongodb-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-mcp-server"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "mongodb+srv://<USERNAME>:<PASSWORD>@miniprojectcluster.fmu4i4o.mongodb.net/?appName=miniprojectcluster"
      },
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate"
    }
  }
}
